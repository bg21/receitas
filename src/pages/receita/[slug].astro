---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const recipes = await getCollection('recipes');
  return recipes.map(recipe => ({
    params: { slug: recipe.id },
    props: { recipe },
  }));
}

const { recipe } = Astro.props;
const { Content } = await render(recipe);

const categoryColors: Record<string, string> = {
  'Aves': 'var(--color-aves)',
  'Peixes': 'var(--color-peixes)',
  'Carne Suína': 'var(--color-suina)',
};

const categoryColor = categoryColors[recipe.data.category] || 'var(--color-primary)';
---

<Layout title={recipe.data.title}>
  <div class="recipe-header" style={`background-color: ${categoryColor}`}>
    <div class="container header-grid">
      <div class="header-content">
        <span class="category">{recipe.data.category}</span>
        <h1>{recipe.data.title}</h1>
        <p class="description">{recipe.data.description}</p>
        
        <div class="meta-pills">
          <div class="pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg>
            <span>{recipe.data.prepTime}</span>
          </div>
          <div class="pill">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
            <span>{recipe.data.servings}</span>
          </div>
        </div>
      </div>
      
      {recipe.data.image && (
        <div class="header-image">
          <img src={recipe.data.image} alt={recipe.data.title} />
        </div>
      )}
    </div>
  </div>

  <div class="container">
    <article class="recipe-content">
      <Content />
    </article>
    
    <div class="back-action">
      <a href="/" class="btn btn-primary">Voltar para Início</a>
    </div>
  </div>
</Layout>

<style is:global>
  .recipe-content h2 {
    color: var(--color-primary);
    border-bottom: 2px solid var(--color-bg);
    padding-bottom: 0.5rem;
    margin: 2.5rem 0 1.5rem;
    font-size: 1.5rem;
  }

  .recipe-content ul, .recipe-content ol {
    margin-bottom: 2rem;
    padding-left: 1.5rem;
  }

  .recipe-content li {
    margin-bottom: 0.75rem;
  }

  .recipe-content ul li::marker {
    color: var(--color-primary);
  }
  
  .recipe-content ol li {
    padding-left: 0.5rem;
  }
  
  .recipe-content ol li::marker {
    color: var(--color-primary);
    font-weight: 700;
  }
</style>

<style>
  .recipe-header {
    color: white;
    padding: 4rem 0;
    margin-bottom: 3rem;
  }

  .header-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .category {
    display: inline-block;
    background-color: rgba(255, 255, 255, 0.2);
    padding: 4px 12px;
    border-radius: var(--border-radius-pill);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }

  h1 {
    font-size: 2.5rem;
    margin-bottom: 1rem;
  }

  .description {
    font-size: 1.125rem;
    opacity: 0.9;
    margin-bottom: 2rem;
  }

  .meta-pills {
    display: flex;
    gap: 1rem;
  }

  .pill {
    background-color: white;
    color: var(--color-text);
    padding: 8px 16px;
    border-radius: var(--border-radius-pill);
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.875rem;
    font-weight: 700;
  }

  .pill svg {
    color: var(--color-primary);
  }

  .header-image {
    border-radius: var(--border-radius-card);
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.2);
    aspect-ratio: 4 / 3;
  }

  .header-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .recipe-content {
    max-width: 800px;
    margin: 0 auto;
    background-color: white;
    padding: 3rem;
    border-radius: var(--border-radius-card);
    box-shadow: var(--shadow);
  }

  .back-action {
    text-align: center;
    margin: 4rem 0;
  }

  @media (max-width: 992px) {
    .header-grid {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    
    .header-image {
      order: -1;
    }
    
    h1 {
      font-size: 2rem;
    }
  }

  @media (max-width: 576px) {
    .recipe-content {
      padding: 1.5rem;
    }
  }
</style>
