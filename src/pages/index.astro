---
import Layout from '../layouts/Layout.astro';
import RecipeCard from '../components/RecipeCard.astro';
import { getCollection } from 'astro:content';

const recipes = await getCollection('recipes');
const allTags = [...new Set(recipes.flatMap(recipe => recipe.data.tags))].sort();
---

<Layout title="Início">
	<section class="hero">
		<div class="container">
			<h1>Minha Receita</h1>
			<p>Explore as melhores receitas com o toque especial que você merece.</p>
		</div>
	</section>

	<div class="container">
		<div class="filter-wrapper">
			<span class="filter-label">Filtrar por:</span>
			<div class="filter-container">
				<button class="filter-btn active" data-tag="all">Todas</button>
				{allTags.map(tag => (
					<button class="filter-btn" data-tag={tag}>{tag}</button>
				))}
			</div>
		</div>

		<div class="recipe-grid">
			{recipes.map(recipe => (
				<RecipeCard 
					title={recipe.data.title}
					description={recipe.data.description}
					image={recipe.data.image}
					category={recipe.data.category}
					prepTime={recipe.data.prepTime}
					servings={recipe.data.servings}
					slug={recipe.id}
					tags={recipe.data.tags}
				/>
			))}
		</div>
	</div>
</Layout>

<script>
	const filterButtons = document.querySelectorAll('.filter-btn');
	const recipeCards = document.querySelectorAll('.recipe-card') as NodeListOf<HTMLElement>;

	filterButtons.forEach(btn => {
		btn.addEventListener('click', () => {
			const tag = btn.getAttribute('data-tag');
			
			// Atualizar estado ativo
			filterButtons.forEach(b => b.classList.remove('active'));
			btn.classList.add('active');

			// Filtrar cards
			recipeCards.forEach(card => {
				const cardTagsAttr = card.getAttribute('data-tags');
				const cardTags = cardTagsAttr ? cardTagsAttr.split(',') : [];
				
				if (tag === 'all' || cardTags.includes(tag || '')) {
					card.style.display = 'flex';
				} else {
					card.style.display = 'none';
				}
			});
		});
	});
</script>

<style>
	.hero {
		background-color: var(--color-bg);
		padding: 4rem 0 3rem;
		text-align: center;
	}

	.hero h1 {
		font-size: 3rem;
		color: var(--color-primary);
		margin-bottom: 1rem;
	}

	.hero p {
		font-size: 1.25rem;
		color: #555;
		max-width: 600px;
		margin: 0 auto;
	}

	.recipe-grid {
		display: grid;
		grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
		gap: 2rem;
		padding: 0 0 4rem;
	}

	.filter-wrapper {
		margin: 2rem 0;
		text-align: center;
	}

	.filter-label {
		display: block;
		font-size: 0.875rem;
		color: #888;
		margin-bottom: 0.75rem;
		font-weight: 500;
	}

	.filter-container {
		display: flex;
		justify-content: center;
		gap: 0.75rem;
		flex-wrap: wrap;
	}

	.filter-btn {
		background-color: white;
		border: 2px solid var(--color-primary);
		color: var(--color-primary);
		padding: 0.4rem 1.25rem;
		border-radius: 999px;
		font-size: 0.875rem;
		font-weight: 600;
		cursor: pointer;
		transition: all 0.2s ease;
	}

	.filter-btn.active, .filter-btn:hover {
		background-color: var(--color-primary);
		color: white;
	}

	@media (max-width: 768px) {
		.hero h1 {
			font-size: 2.25rem;
		}
		
		.recipe-grid {
			grid-template-columns: 1fr;
		}
	}
</style>
